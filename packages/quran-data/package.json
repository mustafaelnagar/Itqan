{
  "name": "@itqan/quran-data",
  "version": "0.1.0",
  "private": true,
  "description": "Bundled, offline-first Quran content — Uthmani text, metadata, and translations. Generated from open sources.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./data/*": "./data/*"
  },
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"@itqan/quran-data: generated data, no tests\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@itqan/types": "workspace:*"
  },
  "devDependencies": {
    "@itqan/config": "workspace:*",
    "eslint": "^8.57.1",
    "typescript": "^5.6.3"
  }
}
