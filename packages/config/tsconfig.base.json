{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@itqan library",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "declarationMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
