# Itqān mobile — environment template.
# Copy to .env.development / .env.staging / .env.production and fill in.
# Only EXPO_PUBLIC_* vars are bundled into the client. Never put secrets here.

# Selects the app variant (development | staging | production).
APP_ENV=development

# Supabase (public anon key only — RLS protects data).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# AI Tasmiʿ service base URL (used from R4 onward).
EXPO_PUBLIC_AI_SERVICE_URL=

# Recitation audio host (EveryAyah layout: <base>/<reciterFolder>/<sssaaa>.mp3).
# Leave blank to use the public EveryAyah CDN, or set to a host you control.
EXPO_PUBLIC_AUDIO_BASE_URL=

# Error logging (Sentry DSN).
EXPO_PUBLIC_SENTRY_DSN=

# Analytics is opt-in and OFF unless explicitly enabled.
EXPO_PUBLIC_ANALYTICS_ENABLED=false
