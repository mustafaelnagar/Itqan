{
  "name": "@itqan/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "description": "Itqān mobile app — Expo + React Native + Expo Router.",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform all",
    "sync:sql-wasm": "node scripts/copy-sql-wasm.mjs",
    "lint": "eslint app src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"@itqan/mobile: tests added in R1\"",
    "clean": "rm -rf .expo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.4",
    "@itqan/analytics": "workspace:*",
    "@itqan/design-system": "workspace:*",
    "@itqan/logging": "workspace:*",
    "@itqan/quran-data": "workspace:*",
    "@itqan/types": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.46.1",
    "@tanstack/react-query": "^5.59.20",
    "expo": "~52.0.11",
    "expo-av": "~15.0.1",
    "expo-clipboard": "~7.0.0",
    "expo-constants": "~17.0.3",
    "expo-file-system": "~18.0.4",
    "expo-font": "~13.0.1",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.9",
    "expo-secure-store": "~14.0.0",
    "expo-sqlite": "~15.0.3",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@itqan/config": "workspace:*",
    "@types/react": "~18.3.12",
    "eslint": "^8.57.1",
    "sql.js": "1.12.0",
    "typescript": "^5.6.3"
  }
}
